<UserControl
    x:Class="ProjetaHDR.RevitAddin.Commands.Waterproofing.Views.CreateWaterproofTypeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    mc:Ignorable="d"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:viewModels="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:CreateWaterproofTypeViewModel}"
    MinWidth="320"
    Width="Auto"
    Height="Auto">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Blue.xaml" />
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Padding="8"
        Background="White">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="*" />
                <RowDefinition
                    Height="32" />
            </Grid.RowDefinitions>

            <Button
                Grid.Row="0"
                Content="+" />
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Grid.Row="1">
                <ItemsControl
                    d:ItemsSource="{d:SampleData ItemCount=1}">
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:CreateWaterproofTypeViewModel}">
                            
                            <Expander d:IsExpanded="False"
                                      Margin="0 8">

                                <Expander.Header>
                                    <TextBlock Text="VEDACIT TOP"/>
                                </Expander.Header>

                                <StackPanel
                                    x:Name="MainContent"
                                    Margin="0 0 0 16"
                                    Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                    Orientation="Vertical">

                                    <StackPanel
                                        Orientation="Vertical"
                                        Margin="0,8">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            Text="Nome" />
                                        <TextBox
                                            Controls:ControlsHelper.CornerRadius="4"
                                            Height="30"
                                            d:Text="VEDACIT TOP"
                                            Text="{Binding WaterproofName}" />
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Vertical">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            Text="Espessura padrão (mm)" />
                                        <Controls:NumericUpDown
                                            Controls:ControlsHelper.CornerRadius="4"
                                            Height="30"
                                            Value="{Binding WaterproofThickness}"
                                            Minimum="1"
                                            NumericInputMode="Numbers"
                                            HideUpDownButtons="True" />
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Horizontal"
                                        Margin="0 16">

                                        <StackPanel
                                            Orientation="Horizontal"
                                            Margin="0 0 16 0">
                                            <CheckBox
                                                Margin="0 0 4 0"
                                                Padding="0"
                                                d:IsChecked="True"
                                                IsChecked="{Binding IsHorizontalWaterproof}" />
                                            <TextBlock
                                                Text="Área horizontal" />
                                        </StackPanel>

                                        <StackPanel
                                            Orientation="Horizontal">
                                            <CheckBox
                                                Margin="0 0 4 0"
                                                Padding="0"
                                                d:IsChecked="True"
                                                IsChecked="{Binding IsVerticalWaterproof}" />
                                            <TextBlock
                                                Text="Área vertical" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid
                x:Name="BottomBar"
                Grid.Row="2">

                <Button
                    Padding="8,0"
                    Background="Transparent"
                    Content="Confirmar"
                    Command="" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
