<UserControl
    x:Class="ProjetaHDR.RevitAddin.Commands.Waterproofing.Views.CreateWaterproofTypeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    mc:Ignorable="d"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:viewModels="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels"
    xmlns:viewModelItems="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels.Wrappers"
    d:DataContext="{d:DesignInstance viewModels:CreateWaterproofTypeViewModel}"
    MinWidth="320"
    Width="Auto"
    Height="Auto">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Blue.xaml" />
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Padding="8"
        Background="White">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="*" />
                <RowDefinition
                    Height="Auto" />
                <RowDefinition
                    Height="32" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                FontWeight="Bold" 
                Text="Camada Principal"/>

            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Grid.Row="1">
                <ItemsControl
                    d:ItemsSource="{d:SampleData ItemCount=2}"
                    ItemsSource="{Binding WaterproofingLayers}">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate
                            DataType="{x:Type viewModelItems:WaterproofingLayerItemViewModel}">

                            <Expander
                                d:IsExpanded="True"
                                Margin="0 8">

                                <Expander.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            d:Text="VEDACIT TOP"
                                            Text="{Binding HeaderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            Margin="8 0"
                                            HorizontalAlignment="Left" 
                                            VerticalAlignment="Center"/>

                                        <Button
                                            Command="{
                                            Binding DataContext.RemoveLayerCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}
                                            }"
                                            CommandParameter="{Binding .}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Grid.Column="1"
                                            Margin="8 0"
                                            HorizontalAlignment="Right">
                                            <iconPacks:PackIconMaterial
                                                Kind="Minus"
                                                Foreground="Red"
                                                />
                                        </Button>
                                    </Grid>
                                </Expander.Header>

                                <StackPanel
                                    x:Name="MainContent"
                                    Margin="0 0 0 16"
                                    Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                    Orientation="Vertical">

                                    <StackPanel
                                        Orientation="Vertical"
                                        Margin="0,8">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            Text="Nome" />
                                        <TextBox
                                            Controls:ControlsHelper.CornerRadius="4"
                                            Height="30"
                                            d:Text="VEDACIT TOP"
                                            Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Vertical">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            Text="Espessura padrão (mm)" />
                                        <Controls:NumericUpDown
                                            Controls:ControlsHelper.CornerRadius="4"
                                            Height="30"
                                            Value="{Binding Thickness}"
                                            Minimum="1"
                                            TextAlignment="Left"
                                            NumericInputMode="Numbers"
                                            HideUpDownButtons="True" />
                                    </StackPanel>

                                    <StackPanel
                                        Orientation="Horizontal"
                                        Margin="0 16 0 0">

                                        <StackPanel
                                            Orientation="Horizontal"
                                            Margin="0 0 16 0">
                                            <CheckBox
                                                Margin="0 0 4 0"
                                                Padding="0"
                                                d:IsChecked="True"
                                                IsChecked="{Binding HasHorizontalArea}" />
                                            <TextBlock
                                                Text="Área horizontal" />
                                        </StackPanel>

                                        <StackPanel
                                            Orientation="Horizontal">
                                            <CheckBox
                                                Margin="0 0 4 0"
                                                Padding="0"
                                                d:IsChecked="True"
                                                IsChecked="{Binding HasVerticalArea}" />
                                            <TextBlock
                                                Text="Área vertical" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button
                Command="{Binding AddNewLayerCommand}"
                Margin="0 0 0 8"
                Grid.Row="2"
                HorizontalAlignment="Right"
                Width="64">
                <iconPacks:PackIconMaterial
                    Kind="Plus"
                    Foreground="{StaticResource MahApps.Brushes.AccentBase}"
                    Width="16"
                    Height="16"
                    ToolTip="Selecionar em projeto o ponto base" />
            </Button>

            <Grid
                x:Name="BottomBar"
                Grid.Row="3">

                <Button
                    Command="{Binding CreateTypeCommand}"
                    Padding="8,0"
                    Background="Transparent"
                    Content="Confirmar"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
