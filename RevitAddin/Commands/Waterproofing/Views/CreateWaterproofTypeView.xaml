<UserControl
    x:Class="ProjetaHDR.RevitAddin.Commands.Waterproofing.Views.CreateWaterproofTypeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModelItems="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels.Wrappers"
    xmlns:viewModels="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels"
    Width="Auto"
    Height="Auto"
    MinWidth="320"
    d:DataContext="{d:DesignInstance viewModels:CreateWaterproofTypeViewModel}"
    d:Height="500"
    d:Width="320"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Blue.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Padding="8" Background="White">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                FontSize="16"
                FontWeight="Bold"
                Text="Camada Principal" />

            <ScrollViewer
                Grid.Row="1"
                Padding="0,0,8,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl d:ItemsSource="{d:SampleData ItemCount=3}" ItemsSource="{Binding WaterproofingLayers}">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModelItems:WaterproofingLayerItemViewModel}">

                            <Expander
                                Margin="0,8"
                                d:IsExpanded="True"
                                IsExpanded="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                                <Expander.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="8,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            d:Text="VEDACIT TOP"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Text="{Binding HeaderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <Button
                                            Grid.Column="1"
                                            Margin="8,0"
                                            HorizontalAlignment="Right"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.RemoveLayerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding .}">
                                            <iconPacks:PackIconMaterial Foreground="Red" Kind="Minus" />
                                        </Button>
                                    </Grid>
                                </Expander.Header>

                                <StackPanel
                                    x:Name="MainContent"
                                    Grid.Row="0"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Stretch"
                                    Orientation="Vertical">

                                    <StackPanel Margin="0,8" Orientation="Vertical">
                                        <TextBlock Margin="0,0,0,4" Text="Nome" />
                                        <TextBox
                                            Height="30"
                                            Controls:ControlsHelper.CornerRadius="4"
                                            d:Text="VEDACIT TOP"
                                            Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Margin="0,0,0,4" Text="Espessura padrão (mm)" />
                                        <Controls:NumericUpDown
                                            Height="30"
                                            Controls:ControlsHelper.CornerRadius="4"
                                            HideUpDownButtons="True"
                                            Minimum="1"
                                            NumericInputMode="Numbers"
                                            TextAlignment="Left"
                                            Value="{Binding Thickness}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">

                                        <StackPanel Margin="0,0,16,0" Orientation="Horizontal">
                                            <CheckBox
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                d:IsChecked="True"
                                                IsChecked="{Binding HasHorizontalArea}" />
                                            <TextBlock Text="Área horizontal" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox
                                                Margin="0,0,4,0"
                                                Padding="0"
                                                d:IsChecked="True"
                                                IsChecked="{Binding HasVerticalArea}" />
                                            <TextBlock Text="Área vertical" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button
                Grid.Row="2"
                Width="64"
                Margin="0,0,0,8"
                HorizontalAlignment="Left"
                Command="{Binding AddNewLayerCommand}">
                <iconPacks:PackIconMaterial
                    Width="16"
                    Height="16"
                    Foreground="{StaticResource MahApps.Brushes.AccentBase}"
                    Kind="Plus"
                    ToolTip="Selecionar em projeto o ponto base" />
            </Button>

            <Grid x:Name="BottomBar" Grid.Row="3">

                <Button
                    Padding="8,0"
                    Background="Transparent"
                    Command="{Binding CreateTypeCommand}"
                    Content="Confirmar" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
