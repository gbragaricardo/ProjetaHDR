<Controls:MetroWindow
    x:Class="ProjetaHDR.RevitAddin.Commands.Waterproofing.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Models"
    xmlns:ui="clr-namespace:ProjetaHDR.UI"
    xmlns:viewModels="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels"
    xmlns:views="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    Title="PROJETA HDR"
    Width="320"
    Height="Auto"
    MinWidth="320"
    MinHeight="360"
    d:DataContext="{d:DesignInstance viewModels:MainViewModel}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Controls:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <DataTemplate DataType="{x:Type viewModels:CreateWaterproofTypeViewModel}">
                        <views:CreateWaterproofTypeView />
                    </DataTemplate>
                </ResourceDictionary>

                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Blue.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Controls:MetroWindow.Resources>

    <Controls:MetroWindow.Flyouts>
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Controls:MetroWindow}}"
                Header="Criar novo tipo"
                IsOpen="{Binding IsFlyoutOpen}"
                Position="Right">

                <Controls:MetroContentControl Content="{Binding CurrentViewModel}" />

            </Controls:Flyout>
        </Controls:FlyoutsControl>
    </Controls:MetroWindow.Flyouts>

    <Border Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <StackPanel
                x:Name="MainContent"
                Grid.Row="0"
                Margin="0,0,0,16"
                HorizontalAlignment="Stretch"
                Orientation="Vertical">

                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Criar piso de impermeabilização" />

                <StackPanel
                    x:Name="Combobox"
                    Margin="0,8"
                    Orientation="Vertical">

                    <TextBlock Margin="0,0,0,4" Text="Material" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Controls:ControlsHelper.CornerRadius="4"
                            DisplayMemberPath="Name"
                            DropDownOpened="ComboBox_OnDropDownOpened"
                            ItemsSource="{Binding WaterproofingFloorTypes, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValue="{Binding SelectedFloorTypeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValuePath="ElementTypeId" />

                        <Button
                            Grid.Column="1"
                            Background="Transparent"
                            Command="{Binding OpenFlyoutCommand}">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Foreground="{StaticResource MahApps.Brushes.AccentBase}"
                                Kind="Plus"
                                ToolTip="Selecionar em projeto o ponto base" />
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="HeightTextBox" Orientation="Vertical">
                    <TextBlock Margin="0,0,0,4" Text="Altura na parede (cm)" />
                    <Controls:NumericUpDown
                        Height="30"
                        Controls:ControlsHelper.CornerRadius="4"
                        HideUpDownButtons="True"
                        Minimum="1"
                        NumericInputMode="Numbers"
                        TextAlignment="Left"
                        Value="{Binding BaseboardHeigth}" />
                </StackPanel>

                <StackPanel
                    x:Name="ThicknessTextBox"
                    Margin="0,8"
                    Orientation="Vertical">
                    <TextBlock Margin="0,0,0,4" Text="Espessura Total (mm)" />
                    <Controls:NumericUpDown
                        Height="30"
                        Controls:ControlsHelper.CornerRadius="4"
                        HideUpDownButtons="True"
                        Minimum="1"
                        NumericInputMode="Numbers"
                        TextAlignment="Left"
                        Value="{Binding WaterproofThickness}" />
                </StackPanel>

                <StackPanel Orientation="Vertical">
                    <TextBlock Margin="0,0,0,4" Text="Deslocamento do nível (cm)" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Controls:NumericUpDown
                            Grid.Column="0"
                            Height="30"
                            Margin="0,0,8,0"
                            Controls:ControlsHelper.CornerRadius="4"
                            HideUpDownButtons="True"
                            Minimum="0"
                            NumericInputMode="Numbers"
                            TextAlignment="Left"
                            Value="{Binding Offset}" />

                        <Button
                            Grid.Column="1"
                            Background="Transparent"
                            Command="{Binding PickOffsetTargetCommand}">
                            <iconPacks:PackIconMaterial
                                Width="16"
                                Height="16"
                                Kind="TargetVariant"
                                ToolTip="Selecionar em projeto o ponto base" />
                        </Button>
                    </Grid>
                </StackPanel>

            </StackPanel>

            <Grid x:Name="BottomBar" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Padding="8,0"
                    Background="Transparent"
                    Command="{Binding CancelCommand}"
                    Content="Cancelar" />

                <Button
                    Grid.Column="2"
                    Padding="8,0"
                    Background="Transparent"
                    Command="{Binding PickRegionsCommand}"
                    Content="Selecionar Regioes" />
            </Grid>
        </Grid>
    </Border>
</Controls:MetroWindow>
