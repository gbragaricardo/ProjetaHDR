<Window x:Class="ProjetaHDR.RevitAddin.Commands.Waterproofing.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
        xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
        xmlns:ui="clr-namespace:ProjetaHDR.UI"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        d:DesignHeight="200"
        d:DesignWidth="360">

    <Window.Resources>
        <ResourceDictionary>
            <converters:BitmapImageConverter x:Key="BitmapImageConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Border Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="MainContent"
                        Grid.Row="0"
                        Orientation="Vertical"
                        HorizontalAlignment="Left">

                <TextBlock Text="Criar piso de impermeabilização" />

                <StackPanel x:Name="Combobox"
                            Margin="0 8"
                            Orientation="Vertical">

                    <TextBlock Text="Material" />

                    <Border CornerRadius="4"
                            BorderThickness="1"
                            BorderBrush="Black"
                            Padding="1"
                            Height="24">
                        
                        <ComboBox BorderThickness="0"
                                  Width="Auto" />
                    </Border>
                </StackPanel>

                <StackPanel x:Name="TextBox"
                            Orientation="Vertical">
                    <TextBlock Text="Altura do rodapé" />

                    <Border CornerRadius="4"
                            BorderThickness="1"
                            BorderBrush="Black"
                            Padding="1"
                            Height="24">
                        <TextBox BorderThickness="0"
                                 Width="Auto" />
                    </Border>
                </StackPanel>

            </StackPanel>

            <Grid x:Name="BottomBar"
                  Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="Black"
                        Background="LightGray">

                    <TextBlock Text="Cancelar"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Black" />
                </Border>

                <Border Grid.Column="2"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="Black"
                        Background="DarkBlue">

                    <TextBlock Text="Selecionar limite"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#EEEEEE" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
