<Controls:MetroWindow
    x:Class="ProjetaHDR.RevitAddin.Commands.Waterproofing.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Models"
    xmlns:ui="clr-namespace:ProjetaHDR.UI"
    xmlns:views="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    xmlns:viewModels="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels"
    MinWidth="320"
    Width="320"
    MinHeight="360"
    Height="Auto"
    d:DataContext="{d:DesignInstance viewModels:MainViewModel}"
    WindowStartupLocation="CenterScreen"
    Title="PROJETA HDR"
    mc:Ignorable="d">

    <Controls:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <DataTemplate
                        DataType="{x:Type viewModels:CreateWaterproofTypeViewModel}">
                        <views:CreateWaterproofTypeView />
                    </DataTemplate>
                </ResourceDictionary>

                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Blue.xaml" />
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary
                    Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Controls:MetroWindow.Resources>

    <Controls:MetroWindow.Flyouts>
        <Controls:FlyoutsControl>
            <Controls:Flyout
                Position="Right"
                Header="Criar novo tipo"
                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Controls:MetroWindow}}"
                IsOpen="{Binding IsFlyoutOpen}">

                <Controls:MetroContentControl
                    Content="{Binding CurrentViewModel}" />

            </Controls:Flyout>
        </Controls:FlyoutsControl>
    </Controls:MetroWindow.Flyouts>

    <Border
        Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="*" />
                <RowDefinition
                    Height="32" />
            </Grid.RowDefinitions>

            <StackPanel
                x:Name="MainContent"
                Margin="0 0 0 16"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                Orientation="Vertical">

                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Criar piso de impermeabilização" />

                <StackPanel
                    x:Name="Combobox"
                    Margin="0,8"
                    Orientation="Vertical">

                    <TextBlock
                        Margin="0,0,0,4"
                        Text="Material" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Controls:ControlsHelper.CornerRadius="4"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding WaterproofingFloorTypes, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValue="{Binding SelectedFloorTypeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            SelectedValuePath="ElementTypeId"
                            DropDownOpened="ComboBox_OnDropDownOpened" />

                        <Button
                            Grid.Column="1"
                            Background="Transparent"
                            Command="{Binding OpenFlyoutCommand}">
                            <iconPacks:PackIconMaterial
                                Kind="Plus"
                                Foreground="Green"
                                Width="16"
                                Height="16"
                                ToolTip="Selecionar em projeto o ponto base" />
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel
                    x:Name="HeightTextBox"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,4"
                        Text="Altura na parede (cm)" />
                    <Controls:NumericUpDown
                        Controls:ControlsHelper.CornerRadius="4"
                        Height="30"
                        Value="{Binding BaseboardHeigth}"
                        Minimum="1"
                        NumericInputMode="Numbers"
                        HideUpDownButtons="True" />
                </StackPanel>

                <StackPanel
                    x:Name="ThicknessTextBox"
                    Margin="0,8"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,4"
                        Text="Espessura Total (mm)" />
                    <Controls:NumericUpDown
                        Controls:ControlsHelper.CornerRadius="4"
                        Height="30"
                        Value="{Binding WaterproofThickness}"
                        Minimum="1"
                        NumericInputMode="Numbers"
                        HideUpDownButtons="True" />
                </StackPanel>

                <StackPanel
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,4"
                        Text="Deslocamento do nível (cm)" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="*" />
                            <ColumnDefinition
                                Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Controls:NumericUpDown
                            Grid.Column="0"
                            Margin="0 0 8 0"
                            Controls:ControlsHelper.CornerRadius="4"
                            Height="30"
                            Value="{Binding Offset}"
                            Minimum="1"
                            NumericInputMode="Numbers"
                            HideUpDownButtons="True" />

                        <Button
                            Grid.Column="1"
                            Background="Transparent"
                            Command="{Binding PickOffsetTargetCommand}">
                            <iconPacks:PackIconMaterial
                                Kind="TargetVariant"
                                Width="16"
                                Height="16"
                                ToolTip="Selecionar em projeto o ponto base" />
                        </Button>
                    </Grid>
                </StackPanel>

            </StackPanel>

            <Grid
                x:Name="BottomBar"
                Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="Auto" />
                    <ColumnDefinition
                        Width="*" />
                    <ColumnDefinition
                        Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Padding="8,0"
                    Background="Transparent"
                    Content="Cancelar"
                    Command="{Binding CancelCommand}" />

                <Button
                    Grid.Column="2"
                    Padding="8,0"
                    Background="Transparent"
                    Content="Selecionar Regioes"
                    Command="{Binding PickRegionsCommand}" />
            </Grid>
        </Grid>
    </Border>
</Controls:MetroWindow>
