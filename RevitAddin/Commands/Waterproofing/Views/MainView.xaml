<Controls:MetroWindow
    x:Class="ProjetaHDR.RevitAddin.Commands.Waterproofing.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.Models"
    xmlns:ui="clr-namespace:ProjetaHDR.UI"
    xmlns:viewModels="clr-namespace:ProjetaHDR.RevitAddin.Commands.Waterproofing.ViewModels"
    Width="360"
    Height="Auto"
    d:DataContext="{d:DesignInstance viewModels:MainViewModel}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Controls:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Blue.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Controls:MetroWindow.Resources>

    <Border Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <StackPanel
                x:Name="MainContent"
                Grid.Row="0"
                HorizontalAlignment="Left"
                Orientation="Vertical">

                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Criar piso de impermeabilização" />

                <StackPanel
                    x:Name="Combobox"
                    Margin="0,8"
                    Orientation="Vertical">

                    <TextBlock Margin="0,0,0,4" Text="Material" />
                    <ComboBox
                        Controls:ControlsHelper.CornerRadius="4"
                        d:SelectedIndex="2"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding AvailableFloorTypes, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValue="{Binding SelectedFloorType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValuePath="ElementTypeId" />
                </StackPanel>

                <StackPanel x:Name="TextBox" Orientation="Vertical">
                    <TextBlock Margin="0,0,0,4" Text="Altura do rodapé (cm)" />
                    <TextBox
                        Controls:ControlsHelper.CornerRadius="4"
                        d:Text="30 cm"
                        Text="{Binding BaseboardHeigth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,8" Orientation="Vertical">
                    <TextBlock Margin="0,0,0,4" Text="Deslocamento do nível (cm)" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="26" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Controls:ControlsHelper.CornerRadius="4"
                            d:Text="0 cm"
                            Text="{Binding BaseboardHeigth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Column="1" />
                    </Grid>
                </StackPanel>

            </StackPanel>

            <Grid x:Name="BottomBar" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Padding="8,0"
                    Background="Transparent"
                    Content="Cancelar" />

                <Button
                    Grid.Column="2"
                    Padding="8,0"
                    Background="Transparent"
                    Content="Selecionar Regioes"
                    Click="BtnSelectRegions_Click"/>
            </Grid>
        </Grid>
    </Border>
</Controls:MetroWindow>
