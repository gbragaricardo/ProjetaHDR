<Window x:Class="ProjetaHDR.UI.Views.DrenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:ProjetaHDR.UI.Views"
        xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
        xmlns:viewModel="clr-namespace:ProjetaHDR.UI.ViewModels"
        d:DataContext="{d:DesignInstance viewModel:DrenViewModel}"
        mc:Ignorable="d" 
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="NoResize"
        Height="600"
        Width="900"
        Background="Transparent"
        Title="ProjetaHDR"
        WindowStartupLocation="CenterScreen">


    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/RadioComboTheme.xaml"/>
                <ResourceDictionary Source="../Themes/TransparentComboTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:BitmapImageConverter x:Key="BitmapImageConverter"/>
        </ResourceDictionary>
        
    </Window.Resources>
    

    


    <Border Background="#F7F7F7"
            Padding="15">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="1"
                          Grid.Column="0">
                <ItemsControl ItemsSource="{Binding AddedFixtureFamilies, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged}"
                              AlternationCount="200">
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton GroupName="Fixtures"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                                     UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource RadioComboTheme}"
                                                 Width="250">

                                        <Grid>
                                            <TextBlock Text="{Binding (ItemsControl.AlternationIndex),
                                                              RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                       VerticalAlignment="Center"
                                                       Margin="10 0 0 0"
                                                       />

                                            <ComboBox ItemsSource="{Binding DataContext.AllFixturesAndComments,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      DisplayMemberPath="Value"
                                                      SelectedValuePath="Key"
                                                      SelectedValue="{Binding InstanceElementId, Mode=TwoWay,
                                                                              UpdateSourceTrigger=PropertyChanged}"
                                                      Margin="0"
                                                      MinWidth="125"
                                                      Style="{StaticResource TransparentCombo}"
                                                      HorizontalAlignment="Right"
                                                      VerticalContentAlignment="Center">

                                            </ComboBox>
                                        </Grid>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    
                    
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal"
                        Grid.Column="0"
                        Grid.Row="2">

                <Button Command="{Binding AddComboBoxCommand}"
                        Grid.Row="1"
                        FontSize="9"
                        Margin="0 0 15 0"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='add.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <Button Command="{Binding RemoveComboBoxCommand}"
                        FontSize="9"
                        Margin="0 0 15 0"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='remove.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <Button Command="{Binding MoveUpCommand}"
                        CommandParameter="{Binding DataContext.SelectedFixture,
                                           RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        FontSize="9"
                        Margin="0 0 15 0"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='arrowup.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <Button Command="{Binding MoveDownCommand}"
                        CommandParameter="{Binding DataContext.SelectedFixture, 
                                           RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        FontSize="9"
                        Margin="0 0 15 0"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='arrowdown.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

            </StackPanel>

            <Grid Grid.Column="1" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="300"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch">
                    
                
                    <TextBlock Text="AREAS"
                               Margin="93.95 0 10 0"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Button Command="{Binding AddAreaCommand}"
                            Margin="0 0 10 0"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                ConverterParameter='add.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button Command="{Binding RemoveAreaCommand}"
                            Margin="0 0 10 0"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                        ConverterParameter='remove.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>


                </StackPanel>

                <ScrollViewer Grid.Column="0" Grid.Row="0"
                              Margin="15"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Height="200">

                    <ItemsControl ItemsSource="{Binding SelectedFixtureFamily.InputAreas , Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"
                                                AlternationCount="200">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <RadioButton GroupName="Areas"
                                                     IsChecked="{Binding IsSelected,
                                                                         Mode=TwoWay,
                                                                         UpdateSourceTrigger=PropertyChanged}"
                                                     
                                                     Style="{StaticResource RadioComboTheme}"
                                                     Width="175">

                                            <Grid>
                                                <TextBlock Text="{Binding (ItemsControl.AlternationIndex),
                                                                           RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                           
                                                           VerticalAlignment="Center"
                                                           Margin="10 0 0 0"/>

                                                <ComboBox ItemsSource="{Binding DataContext.AllDocumentAreas,
                                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          DisplayMemberPath="Value"
                                                          SelectedValuePath="Key"
                                                          SelectedValue="{Binding InstanceElementId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0"
                                                          MinWidth="80"
                                                          MaxWidth="150"
                                                          Style="{StaticResource TransparentCombo}"
                                                          HorizontalAlignment="Right"
                                                          VerticalContentAlignment="Center">

                                                </ComboBox>
                                            </Grid>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>




                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">


                    <TextBlock Text="PECAS"
                               Margin="93.95 0 10 0"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Button Command="{Binding AddInputFixtureCommand}"
                            Margin="0 0 10 0"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                ConverterParameter='add.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>

                    <Button Command="{Binding RemoveInputFixtureCommand}"
                            Margin="0 0 10 0"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                        ConverterParameter='remove.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>

                <ScrollViewer Grid.Column="1" Grid.Row="0"
                              Margin="15"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Height="200">

                    <ItemsControl ItemsSource="{Binding SelectedFixtureFamily.InputFixtureItems , Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged}"
                                AlternationCount="200">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <RadioButton GroupName="Pecas"
                                                     IsChecked="{Binding InputFixtureSelected,
                                                                 Mode=TwoWay,
                                                                 UpdateSourceTrigger=PropertyChanged}"
                                                     
                                                     Style="{StaticResource RadioComboTheme}"
                                                     Width="175">

                                            <Grid>
                                                <TextBlock Text="{Binding (ItemsControl.AlternationIndex),
                                                                  RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                           VerticalAlignment="Center"
                                                           Margin="10 0 0 0"/>

                                                <ComboBox ItemsSource="{Binding DataContext.AddedFixtureFamilies, Mode=TwoWay,
                                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          DisplayMemberPath="Description"
                                                          SelectedValuePath="InstanceElementId"
                                                          SelectedValue="{Binding InstanceElementId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0"
                                                          MinWidth="80"
                                                          MaxWidth="150"
                                                          Style="{StaticResource TransparentCombo}"
                                                          HorizontalAlignment="Right"
                                                          VerticalContentAlignment="Center">

                                                </ComboBox>
                                            </Grid>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Border>
</Window>
