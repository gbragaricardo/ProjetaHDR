<Window
    x:Class="ProjetaHDR.UI.Views.DrenWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjetaHDR.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:ProjetaHDR.UI.ViewModels"
    Title="ProjetaHDR"
    Width="900"
    Height="625"
    MinWidth="900"
    MinHeight="625"
    MaxWidth="900"
    d:DataContext="{d:DesignInstance viewModel:DrenViewModel}"
    Background="Transparent"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow"
    mc:Ignorable="d">

    <!--  Temas e Converters  -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/RadioComboTheme.xaml" />
                <ResourceDictionary Source="../Themes/TransparentComboTheme.xaml" />
                <ResourceDictionary Source="../Themes/BlueButtonTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>


            <FontFamily x:Key="MontserratFont">
                pack://application:
                ,,,/ProjetaHDR;component/UI/Montserrat-VariableFont_wght.ttf#Montserrat
            </FontFamily>
            <converters:BitmapImageConverter x:Key="BitmapImageConverter" />
        </ResourceDictionary>

    </Window.Resources>

    <Border Padding="15" Background="White">

        <!--  GRID GERAL  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <!--  Faixa Superior  -->
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Foreground="#0784bc"
                Text="PEÇAS PLUVIAIS" />

            <TextBlock
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Foreground="#0784bc"
                Text="ENTRADAS" />
            <!--  Fim Faixa Superior  -->

            <!--  Main ScrollViwer  -->
            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Orientation="Horizontal">

                <Button
                    Grid.Row="1"
                    Width="25"
                    Height="25"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Command="{Binding AddComboBoxCommand}"
                    FontSize="9">

                    <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='add.png'}" />
                </Button>

                <Button
                    Width="25"
                    Height="25"
                    Margin="15,0,7.5,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Command="{Binding RemoveComboBoxCommand}"
                    FontSize="9">

                    <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='remove.png'}" />
                </Button>

                <Button
                    Width="25"
                    Height="25"
                    Margin="7.5,0,15,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Command="{Binding MoveUpCommand}"
                    CommandParameter="{Binding DataContext.SelectedFixture, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    FontSize="9">

                    <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='arrowup.png'}" />
                </Button>

                <Button
                    Width="25"
                    Height="25"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Command="{Binding MoveDownCommand}"
                    CommandParameter="{Binding DataContext.SelectedFixture, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    FontSize="9">

                    <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='arrowdown.png'}" />
                </Button>

            </StackPanel>

            <ScrollViewer
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,50,10,0">
                <ItemsControl
                    HorizontalAlignment="Center"
                    AlternationCount="200"
                    ItemsSource="{Binding AddedFixtureFamilies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton
                                        Width="250"
                                        GroupName="Fixtures"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource RadioComboTheme}">

                                        <Grid>
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="Black"
                                                Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource Mode=TemplatedParent}}" />

                                            <ComboBox
                                                MinWidth="125"
                                                Margin="0"
                                                HorizontalAlignment="Right"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="Value"
                                                FontWeight="Bold"
                                                ItemsSource="{Binding DataContext.AllFixturesAndComments, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                SelectedValue="{Binding InstanceElementId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectedValuePath="Key"
                                                Style="{StaticResource TransparentCombo}" />
                                        </Grid>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>


                </ItemsControl>
            </ScrollViewer>
            <!--  FIM Main ScrollViwer  -->


            <!--  GRID PEÇA SELECIONADA  -->
            <Grid
                Grid.Row="1"
                Grid.Column="1"
                Visibility="{Binding HasSelected, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="250" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>


                <!--  SCROLL INPUT AREAS  -->
                <StackPanel
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">


                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#0784bc"
                        Text="ÁREAS" />

                    <Button
                        Width="25"
                        Height="25"
                        Margin="10,0,10,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding AddAreaCommand}">

                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='add.png'}" />
                    </Button>
                    <Button
                        Width="25"
                        Height="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding RemoveAreaCommand}">

                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='remove.png'}" />
                    </Button>
                </StackPanel>

                <ScrollViewer
                    Grid.Row="0"
                    Grid.Column="0"
                    Width="220"
                    Margin="15,50,15,40"
                    Padding="0,0,5,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch">

                    <ItemsControl AlternationCount="200" ItemsSource="{Binding SelectedFixtureFamily.InputAreas, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                                        <RadioButton
                                            Width="175"
                                            GroupName="Areas"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource RadioComboTheme}">

                                            <Grid>

                                                <ComboBox
                                                    Width="100"
                                                    HorizontalAlignment="Left"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    DisplayMemberPath="Value"
                                                    FontWeight="Bold"
                                                    ItemsSource="{Binding DataContext.AllDocumentAreas, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    SelectedValue="{Binding InstanceElementId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectedValuePath="Key"
                                                    Style="{StaticResource TransparentCombo}" />

                                                <TextBlock
                                                    Margin="0,0,15,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontWeight="Bold"
                                                    Text="{Binding FlowRate, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <!--  FIM SCROLL INPUT AREAS  -->


                <!--  SCROLL INPUT PECAS  -->
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Orientation="Horizontal">


                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#0784bc"
                        Text="PEÇAS" />

                    <Button
                        Width="25"
                        Height="25"
                        Margin="10,0,10,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding AddInputFixtureCommand}">

                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='add.png'}" />
                    </Button>

                    <Button
                        Width="25"
                        Height="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Command="{Binding RemoveInputFixtureCommand}">

                        <Image RenderOptions.BitmapScalingMode="HighQuality" Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='remove.png'}" />
                    </Button>
                </StackPanel>

                <ScrollViewer
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="220"
                    Margin="15,50,15,40"
                    Padding="0,0,5,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch">

                    <ItemsControl AlternationCount="200" ItemsSource="{Binding SelectedFixtureFamily.InputFixtureItems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                                        <RadioButton
                                            Width="175"
                                            GroupName="Pecas"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource RadioComboTheme}">

                                            <Grid>

                                                <ComboBox
                                                    Width="100"
                                                    Margin="0"
                                                    HorizontalAlignment="Left"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    DisplayMemberPath="Description"
                                                    FontWeight="Bold"
                                                    ItemsSource="{Binding DataContext.AddedFixtureFamilies, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    SelectedValue="{Binding CorrespondentFixture, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource TransparentCombo}" />

                                                <TextBlock
                                                    Margin="0,0,15,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontWeight="Bold"
                                                    Text="{Binding CorrespondentFixture.FlowRate, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                                            </Grid>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <!--  FIM SCROLL INPUT PECAS  -->


                <!--  LINHA AZUL  -->
                <Border
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Width="Auto"
                    Height="2"
                    Margin="25,10"
                    VerticalAlignment="Bottom"
                    Background="#0784bc"
                    CornerRadius="1" />
                <!--  FIM LINHA AZUL  -->

                <!--  FAIXA COM TEXTO SAÍDA  -->
                <StackPanel
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Height="25"
                    VerticalAlignment="Top">
                    <TextBlock
                        Margin="0"
                        HorizontalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#0784bc"
                        Text="SAÍDA" />
                </StackPanel>
                <!--  FIM FAIXA COM TEXTO SAÍDA  -->

                <!--  TUBOS SELECIONADOS  -->
                <StackPanel
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch">

                    <Button
                        Width="150"
                        Height="30"
                        HorizontalAlignment="Center"
                        Command="{Binding SelectPipesCommand}"
                        Content="SELECIONAR TUBOS"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource BlueButton}" />


                    <ItemsControl AlternationCount="200" ItemsSource="{Binding ClassifiedOutputPipes, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Width="225"
                                    Margin="0,15,0,0"
                                    Padding="10"
                                    Background="#83C1DD"
                                    CornerRadius="5">

                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontWeight="Bold"
                                            Text="TUBOS DE SAÍDA:" />

                                        <TextBlock
                                            Margin="0,0,10,0"
                                            FontWeight="Bold"
                                            Text="{Binding ., Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <!--  FIM TUBOS SELECIONADOS  -->

                <!--  ANALISE DA VAZAO  -->
                <StackPanel
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Center">

                    <Border Width="150" Height="30">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="ExtraBold"
                            Foreground="#0784bc"
                            Text="VAZÃO DE SAÍDA" />
                    </Border>

                    <Border
                        Margin="0,15,0,0"
                        Padding="10"
                        Background="#0784bc"
                        CornerRadius="5">
                        <StackPanel>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource MontserratFont}"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="VAZÃO TOTAL:" />

                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource MontserratFont}"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding SelectedFixtureFamily.FlowRate, StringFormat=' {0} L/min ', Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Margin="0,15,0,0"
                        Padding="10"
                        Background="#0784bc"
                        CornerRadius="5">
                        <StackPanel>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource MontserratFont}"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="VAZÃO P/ CONDUTOR:" />

                            <TextBlock
                                Margin="0,5,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource MontserratFont}"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding SelectedFixtureFamily.FlowPerConductor, StringFormat=' {0} L/min ', Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                </StackPanel>
                <!--  FIM ANALISE DA VAZAO  -->

            </Grid>
            <!--  FIM GRID PEÇA SELECIONADA  -->

            <Button
                Grid.Row="2"
                Grid.Column="1"
                Width="150"
                Height="25"
                Command="{Binding ExecuteCommand}"
                Content="EXECUTAR"
                FontWeight="Bold"
                Foreground="White"
                Style="{StaticResource BlueButton}" />
        </Grid>
    </Border>
</Window>
