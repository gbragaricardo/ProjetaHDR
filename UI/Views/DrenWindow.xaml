<Window x:Class="ProjetaHDR.UI.Views.DrenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:ProjetaHDR.UI.Views"
        xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
        xmlns:viewModel="clr-namespace:ProjetaHDR.UI.ViewModels"
        d:DataContext="{d:DesignInstance viewModel:DrenViewModel}"
        mc:Ignorable="d" 
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize"
        Height="600"
        Width="900"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Title="ProjetaHDR">

    <!--Temas e Converters-->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/RadioComboTheme.xaml"/>
                <ResourceDictionary Source="../Themes/TransparentComboTheme.xaml"/>
                <ResourceDictionary Source="../Themes/BlueButtonTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:BitmapImageConverter x:Key="BitmapImageConverter"/>

        </ResourceDictionary>

    </Window.Resources>

    <Border Background="White"
            Padding="15">

        <!--GRID GERAL-->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!--Faixa Superior-->
            <TextBlock Grid.Column="0" Grid.Row="0"
                       Text="PEÇAS PLUVIAIS"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" FontWeight="Bold"
                       Foreground="#0784bc"/>

            <TextBlock Grid.Column="1" Grid.Row="0"
                       Text="ENTRADAS"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" FontWeight="Bold"
                       Foreground="#0784bc"/>
            <!--Fim Faixa Superior-->

            <!--Main ScrollViwer-->
            <StackPanel Orientation="Horizontal"
                        Grid.Column="0" Grid.Row="1"
                        VerticalAlignment="Top" HorizontalAlignment="Center">

                <Button Command="{Binding AddComboBoxCommand}"
                        Grid.Row="1"
                        FontSize="9"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='add.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <Button Command="{Binding RemoveComboBoxCommand}"
                        FontSize="9"
                        Margin="15 0 7.5 0"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='remove.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <Button Command="{Binding MoveUpCommand}"
                        CommandParameter="{Binding DataContext.SelectedFixture,
                                           RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        FontSize="9"
                        Margin="7.5 0 15 0"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='arrowup.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <Button Command="{Binding MoveDownCommand}"
                        CommandParameter="{Binding DataContext.SelectedFixture, 
                                           RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        FontSize="9"
                        Height="25"
                        Width="25"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">

                    <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                            ConverterParameter='arrowdown.png'}"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Grid.Column="0" Margin="0 50 10 0">
                <ItemsControl ItemsSource="{Binding AddedFixtureFamilies, Mode=TwoWay,
                                            UpdateSourceTrigger=PropertyChanged}"
                              AlternationCount="200"
                              HorizontalAlignment="Center">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton GroupName="Fixtures"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                                     UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource RadioComboTheme}"
                                                 Width="250">

                                        <Grid>
                                            <TextBlock Text="{Binding (ItemsControl.AlternationIndex),
                                                              RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                       VerticalAlignment="Center"
                                                       Margin="10 0 0 0"
                                                       />

                                            <ComboBox ItemsSource="{Binding DataContext.AllFixturesAndComments,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      DisplayMemberPath="Value"
                                                      SelectedValuePath="Key"
                                                      SelectedValue="{Binding InstanceElementId, Mode=TwoWay,
                                                                              UpdateSourceTrigger=PropertyChanged}"
                                                      Margin="0"
                                                      MinWidth="125"
                                                      Style="{StaticResource TransparentCombo}"
                                                      HorizontalAlignment="Right"
                                                      VerticalContentAlignment="Center">

                                            </ComboBox>
                                        </Grid>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>


                </ItemsControl>
            </ScrollViewer>
            <!--FIM Main ScrollViwer-->


            <!--GRID PEÇA SELECIONADA-->
            <Grid Grid.Column="1" Grid.Row="1"
                  Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="250"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <!--SCROLL INPUT AREAS-->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center">
                    
                
                    <TextBlock Text="AREAS"
                               Foreground="#0784bc" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Button Command="{Binding AddAreaCommand}"
                            Margin="10 0 10 0"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                ConverterParameter='add.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button Command="{Binding RemoveAreaCommand}"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                        ConverterParameter='remove.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>


                </StackPanel>

                <ScrollViewer Grid.Column="0" Grid.Row="0"
                              Margin="15"
                              Padding="0 0 5 0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Height="150"
                              Width="220">

                    <ItemsControl ItemsSource="{Binding SelectedFixtureFamily.InputAreas , Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"
                                                AlternationCount="200">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <RadioButton GroupName="Areas"
                                                     IsChecked="{Binding IsSelected,
                                                                         Mode=TwoWay,
                                                                         UpdateSourceTrigger=PropertyChanged}"
                                                     
                                                     Style="{StaticResource RadioComboTheme}"
                                                     Width="175">

                                            <Grid>

                                                <ComboBox ItemsSource="{Binding DataContext.AllDocumentAreas,
                                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          DisplayMemberPath="Value"
                                                          SelectedValuePath="Key"
                                                          SelectedValue="{Binding InstanceElementId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Width="100"
                                                          HorizontalContentAlignment="Center"
                                                          Style="{StaticResource TransparentCombo}"
                                                          HorizontalAlignment="Left"
                                                          VerticalContentAlignment="Center"/>

                                                <TextBlock Text="{Binding FlowRate, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           Margin="0 0 15 0"/>
                                            </Grid>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <!--FIM SCROLL INPUT AREAS-->


                <!--SCROLL INPUT PECAS-->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">


                    <TextBlock Text="PECAS"
                               Foreground="#0784bc" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Button Command="{Binding AddInputFixtureCommand}"
                            Margin="10 0 10 0"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                ConverterParameter='add.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>

                    <Button Command="{Binding RemoveInputFixtureCommand}"
                            Height="25"
                            Width="25"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">

                        <Image Source="{Binding Converter={StaticResource BitmapImageConverter},
                                        ConverterParameter='remove.png'}"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>

                <ScrollViewer Grid.Column="1" Grid.Row="0"
                              Margin="15"
                              HorizontalAlignment="Center"
                              Padding="0 0 5 0"
                              VerticalAlignment="Center"
                              Height="150"
                              Width="220">

                    <ItemsControl ItemsSource="{Binding SelectedFixtureFamily.InputFixtureItems , Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged}"
                                AlternationCount="200">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">

                                        <RadioButton GroupName="Pecas"
                                                     IsChecked="{Binding IsSelected,
                                                                 Mode=TwoWay,
                                                                 UpdateSourceTrigger=PropertyChanged}"
                                                     
                                                     Style="{StaticResource RadioComboTheme}"
                                                     Width="175">

                                            <Grid>

                                                <ComboBox ItemsSource="{Binding DataContext.AddedFixtureFamilies, Mode=TwoWay,
                                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          DisplayMemberPath="Description"
                                                          SelectedValue="{Binding CorrespondentFixture, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0"
                                                          Width="100"
                                                          Style="{StaticResource TransparentCombo}"
                                                          HorizontalAlignment="Left"
                                                          HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"/>

                                                <TextBlock Text="{Binding CorrespondentFixture.FlowRate, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           Margin="0 0 15 0"/>
                                                
                                            </Grid>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <!--FIM SCROLL INPUT PECAS-->


                <!--LINHA AZUL-->
                <Border Grid.ColumnSpan="2" Grid.Row="0"
                        Margin="25 10"
                        Width="Auto" Height="2"
                        CornerRadius="1"
                        VerticalAlignment="Bottom"
                        Background="#0784bc"/>
                <!--FIM LINHA AZUL-->

                <!--FAIXA COM TEXTO SAÍDA-->
                <StackPanel Grid.ColumnSpan="2" Grid.Row="1"
                            Height="25"
                            VerticalAlignment="Top">
                    <TextBlock Margin="0"
                               HorizontalAlignment="Center"
                               FontSize="16" FontWeight="Bold"
                               Text="SAÍDA" Foreground="#0784bc"/>
                </StackPanel>
                <!--FIM FAIXA COM TEXTO SAÍDA-->

                <!--TUBOS SELECIONADOS-->
                <StackPanel Grid.Column="0" Grid.Row="2"
                            HorizontalAlignment="Stretch">

                    <Button Command="{Binding SelectPipesCommand}"
                            HorizontalAlignment="Center"
                            Margin="0 0 0 10"
                            Width="150" Height="30"
                            Content="SELECIONAR TUBOS"
                            Foreground="White" FontWeight="Bold"
                            Style="{StaticResource BlueButton}"/>


                    <ItemsControl ItemsSource="{Binding ClassifiedOutputPipes,
                                                Mode=OneWay,
                                                UpdateSourceTrigger=PropertyChanged}"
                                  
                                  AlternationCount="200">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Margin="0 0 10 0"
                                                   Text="{Binding ., 
                                                          Mode=OneWay, 
                                                          UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                   
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <!--FIM TUBOS SELECIONADOS-->

                <!--ANALISE DA VAZAO-->
                <StackPanel Grid.Column="1" Grid.Row="2"
                            HorizontalAlignment="Center">

                    <Border Background="#0784bc"
                            Width="150" Height="30">
                        <Border.Effect>

                            <DropShadowEffect Color="Black" 
                                              Direction="320" 
                                              ShadowDepth="2.5" 
                                              BlurRadius="1" 
                                              Opacity="0.2"/>
                            
                        </Border.Effect>
                        <TextBlock Text="VAZÃO DE SAÍDA"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </Border>
                    
                    <TextBlock Margin="0 15 0 0"
                               Text="{Binding SelectedFixtureFamily.FlowRate,
                                      StringFormat=' {0} L/min ',
                                      Mode=OneWay, 
                                      UpdateSourceTrigger=PropertyChanged}"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"/>

                </StackPanel>
                <!--FIM ANALISE DA VAZAO-->
                
            </Grid>
            <!--FIM GRID PEÇA SELECIONADA-->
            
            
            
            <!--<StackPanel Grid.Column="2" 
                        Grid.ColumnSpan="2" Grid.Row="2"
                        HorizontalAlignment="Center">

                <Button Content="AREAS TESTE"
                        Command="{Binding SetAreasGPCommand}"/>

            </StackPanel>-->
        </Grid>
    </Border>
</Window>
