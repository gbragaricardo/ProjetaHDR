<Window
    x:Class="ProjetaHDR.UI.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ProjetaHDR.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ProjetaHDR.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:ProjetaHDR.UI.ViewModels"
    Title="ProjetaHDR"
    Width="450"
    Height="350"
    d:DataContext="{d:DesignInstance viewModel:LoginViewModel}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="ToolWindow"
    mc:Ignorable="d">


    <Window.Resources>
        <converters:BitmapImageConverter x:Key="BitmapImageConverter" />
    </Window.Resources>

    <Border Padding="10" Background="#E7E7E7">

        <StackPanel>

            <Image
                Width="150"
                HorizontalAlignment="Center"
                RenderOptions.BitmapScalingMode="HighQuality"
                Source="{Binding Converter={StaticResource BitmapImageConverter}, ConverterParameter='logo-projeta-main.png'}"
                Stretch="Uniform" />

            <Label
                Margin="50,25,50,0"
                Padding="0,5"
                Content="Usuário"
                FontFamily="Arial"
                FontWeight="Bold"
                Foreground="Black" />

            <Border
                Height="25"
                Margin="50,0"
                Padding="5"
                Background="White"
                CornerRadius="5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Setters>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        BlurRadius="2"
                                        Direction="320"
                                        Opacity="0.5"
                                        ShadowDepth="0.5"
                                        Color="DarkGray" />
                                </Setter.Value>

                            </Setter>
                        </Style.Setters>
                    </Style>

                </Border.Style>

                <TextBox
                    Height="Auto"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderThickness="0"
                    Text="{Binding Username}" />
            </Border>

            <Label
                Margin="50,10,50,0"
                Padding="0,5"
                Content="Senha"
                FontFamily="Arial"
                FontWeight="Bold"
                Foreground="Black" />

            <Border
                Height="25"
                Margin="50,0"
                Padding="5"
                Background="White"
                CornerRadius="5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Setters>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        BlurRadius="2"
                                        Direction="320"
                                        Opacity="0.5"
                                        ShadowDepth="0.5"
                                        Color="DarkGray" />
                                </Setter.Value>

                            </Setter>
                        </Style.Setters>
                    </Style>

                </Border.Style>

                <PasswordBox
                    x:Name="PasswordInput"
                    Height="Auto"
                    Background="White"
                    BorderThickness="0" />
            </Border>

            <Button
                Width="75"
                Margin="0,25"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                Command="{Binding LoginCommand}"
                CommandParameter="{Binding ElementName=PasswordInput}"
                Content="Login"
                IsDefault="True"
                IsEnabled="{Binding IsLoggedOff}" />

            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="{Binding Message}" />

        </StackPanel>

    </Border>
</Window>